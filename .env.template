# NImageManager configuration
#
# Copy this file to ".env" to override defaults.
# If ".env" does not exist, the launcher will create it from this template.
#
# Public base URL used for links (password setup/reset, etc).
# If set, Quick Tunnel will NOT be started or shown.
#
# Example:
# NAI_IM_PUBLIC_BASE_URL=https://your-domain.example.com
NAI_IM_PUBLIC_BASE_URL=

# Performance instrumentation log (JSONL)
# 1: enabled / 0: disabled
NAI_IM_PERF_LOG_ENABLED=0

# Rotating perf log settings
NAI_IM_PERF_LOG_MAX_BYTES=5242880
NAI_IM_PERF_LOG_BACKUP_COUNT=5

# SQLite busy timeouts (milliseconds)
NAI_IM_SQLITE_BUSY_TIMEOUT_MS=10000
NAI_IM_QUEUE_SQLITE_BUSY_TIMEOUT_MS=10000

# Derivative image settings
# - grid: small gallery thumbnail
# - overlay: larger viewer thumbnail / prefetch target
# - WEBP method: 0=fastest, 6=slowest / smallest
# - AVIF speed: 0=slowest, 10=fastest
# - AVIF codec: auto / aom / rav1e / svt
# - AVIF max threads: 0 means Pillow default

NAI_IM_DERIV_GRID_MAX_SIDE=320
NAI_IM_DERIV_GRID_WEBP_QUALITY=70
NAI_IM_DERIV_GRID_WEBP_METHOD=4
NAI_IM_DERIV_GRID_WEBP_LOSSLESS=0
NAI_IM_DERIV_GRID_WEBP_ALPHA_QUALITY=80
NAI_IM_DERIV_GRID_AVIF_ENABLED=1
NAI_IM_DERIV_GRID_AVIF_QUALITY=70
NAI_IM_DERIV_GRID_AVIF_SPEED=8
NAI_IM_DERIV_GRID_AVIF_CODEC=auto
NAI_IM_DERIV_GRID_AVIF_MAX_THREADS=0

NAI_IM_DERIV_OVERLAY_MAX_SIDE=1400
NAI_IM_DERIV_OVERLAY_WEBP_QUALITY=82
NAI_IM_DERIV_OVERLAY_WEBP_METHOD=4
NAI_IM_DERIV_OVERLAY_WEBP_LOSSLESS=0
NAI_IM_DERIV_OVERLAY_WEBP_ALPHA_QUALITY=92
NAI_IM_DERIV_OVERLAY_AVIF_ENABLED=1
NAI_IM_DERIV_OVERLAY_AVIF_QUALITY=82
NAI_IM_DERIV_OVERLAY_AVIF_SPEED=8
NAI_IM_DERIV_OVERLAY_AVIF_CODEC=auto
NAI_IM_DERIV_OVERLAY_AVIF_MAX_THREADS=0

# Update notification check
# 1: enabled / 0: disabled
NAI_IM_UPDATE_CHECK_ENABLED=1

# Check interval in hours (minimum 1 hour)
NAI_IM_UPDATE_CHECK_INTERVAL_HOURS=24

# GitHub repository to inspect. "owner/repo" or GitHub URL can be used.
NAI_IM_UPDATE_REPO=retroaegx/NImageManager
