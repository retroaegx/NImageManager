{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.2.23",
  "description": "__MSG_extDescription__",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://novelai.net/*",
        "https://*.novelai.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "__MSG_extActionTitle__"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://novelai.net/*",
        "https://*.novelai.net/*"
      ]
    }
  ],
  "default_locale": "en"
}